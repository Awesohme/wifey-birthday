# ── Supabase (client-safe) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (server-only — NEVER prefix with NEXT_PUBLIC_) ──
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Passcode for the /admin moderation page (server-checked)
ADMIN_PASSCODE=

# Reveal override for testing: "open" forces the experience unlocked,
# "locked" forces the countdown. Leave empty in production.
REVEAL_OVERRIDE=
